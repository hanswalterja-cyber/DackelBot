#include <Arduino.h>
#include "distance.hpp"
#include "buzzer.hpp"
#include "rgbLED.hpp"
#include "servoEars.hpp"
#include "servoTail.hpp"


void setup(){
  setupBuzzer();
  setupEcho();
  setupLED();
  setupServo();
}

unsigned long lastMovementTime = 0; // Speichert den Zeitpunkt der letzten Bewegung
bool isInIdleMode = false;          // Status, ob wir gerade im Ruhemodus s

void loop() {
  double a = get_direction_of_motion();
  float schwellenwert = 5.0; // Ignoriere alles zwischen -5 und +5

  // 1. ECHTE BEWEGUNG ERKANNT (außerhalb der Totzone)
  if (abs(a) > schwellenwert) { 
    lastMovementTime = millis();
    isInIdleMode = false;

    if (a < -100) {                           
      color(255, 200, 0);
      setServo(75);
      makeSound(200, 100);
    }
    else if (a >= -100 && a < -schwellenwert) { // Geändert: Grenze zum Schwellenwert
      color(0, 255, 0);
      setServo(120);
      makeSound(250, 50);
    }
    else if (a > schwellenwert && a < 100) {    // Geändert: Grenze zum Schwellenwert
      color(255, 0, 25);
      setServo(0);
      makeSound(75, 200);
    }
    else if (a >= 100) {                   
      color(0, 0, 255);
      setServo(30);
      makeSound(150, 400);
    }
    
    delay(100);
    noTone(buzzerPin);
  } 
  // 2. STILLSTAND ODER NUR MINIMALES RAUSCHEN
  else {
    if (!isInIdleMode && (millis() - lastMovementTime > 5000)) {
      color(0, 255, 255); // Initialzustand (Cyan)
      setServo(90);
      noTone(buzzerPin);
      isInIdleMode = true;
    }
  }
}

